# @saflib/env
ALLOW_DB_CREATION=true
DEPLOYMENT_NAME=development
MOCK_INTEGRATIONS=true
NODE_ENV=development
PROTOCOL=http
TZ=UTC

# example-specific @saflib/env
TRADEMARK=Example
DOMAIN=docker.localhost
CLIENT_SUBDOMAINS=,auth,app,admin,account
SERVICE_SUBDOMAINS=identity,example

KRATOS_COURIER_HTTP_HOST=monolith:3000
SENTRY_DSN=mock

# @saflib/email
NODEMAILER_TRANSPORT_CONFIG=

# @your-org/example-http
EXAMPLE_SERVICE_HTTP_HOST=monolith:3001

ADMIN_EMAILS=admin@your-org.com